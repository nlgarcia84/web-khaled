---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Biografía">
  <!-- SECCIÓN 1: CABECERA EDITORIAL Y LIMPIA -->
  <section class="bg-white pt-24 pb-16">
    <div class="max-w-[1140px] mx-auto px-6">
      <div class="max-w-[800px]">
        <span
          class="font-sans text-xs font-bold tracking-[0.2em] text-oro uppercase block mb-4"
        >
          Sobre el Autor
        </span>
        <h1
          class="font-serif text-4xl md:text-6xl font-bold tracking-tight text-chocolate mb-8 leading-tight"
        >
          Sheij Khaled Huerta
        </h1>
        <p
          class="font-sans text-lg md:text-xl text-marron font-light leading-relaxed"
        >
          Un camino riguroso dedicado a la preservación, traducción y difusión
          de las ciencias tradicionales del Islam en lengua española.
        </p>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 2: LA CRONOLOGÍA ACADÉMICA EN FONDO BLANCO -->
  <section class="py-16 bg-white border-t border-gray-100">
    <div class="max-w-[1140px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
        <!-- Columna Izquierda: Introducción Fija al hacer Scroll -->
        <div class="lg:col-span-4 lg:sticky lg:top-28 h-fit space-y-4">
          <h2 class="font-serif text-2xl md:text-3xl font-bold text-chocolate">
            Metodología y Enfoque
          </h2>
          <div class="w-12 h-[2px] bg-oro"></div>
          <p class="text-marron text-sm leading-relaxed max-w-sm">
            Formación tradicional estructurada bajo la estricta supervisión de
            eruditos, priorizando la cadena de transmisión autorizada (Ijazah) y
            la rectitud en los modales.
          </p>
        </div>

        <!-- Columna Derecha: Línea de Tiempo Sin Cajas, Minimalista -->
        <div
          class="lg:col-span-8 space-y-16 relative before:absolute before:left-4 before:top-2 before:bottom-2 before:w-[1px] before:bg-gray-100"
        >
          <!-- Hito 1 -->
          <div class="relative pl-12 group">
            <!-- Punto sutil en la línea -->
            <div
              class="absolute left-[13px] top-2 w-2 h-2 rounded-full bg-oro/40 group-hover:bg-oro transition-colors duration-300"
            >
            </div>

            <h3
              class="font-serif text-xl font-bold text-chocolate mb-3 group-hover:text-granate transition-colors"
            >
              Transmisión en Lengua Española
            </h3>
            <p class="text-chocolate/80 text-base leading-relaxed max-w-2xl">
              Consolidación de una metodología adaptada al entorno
              hispanohablante. Traduciendo textos clásicos de referencia en
              jurisprudencia (Fiqh), credo ('Aqidah) y ciencias del Hadiz sin
              alterar el rigor académico original.
            </p>
          </div>

          <!-- Hito 2 -->
          <div class="relative pl-12 group">
            <div
              class="absolute left-[13px] top-2 w-2 h-2 rounded-full bg-oro/40 group-hover:bg-oro transition-colors duration-300"
            >
            </div>

            <h3
              class="font-serif text-xl font-bold text-chocolate mb-3 group-hover:text-granate transition-colors"
            >
              Formación y Ciencias Tradicionales
            </h3>
            <p class="text-chocolate/80 text-base leading-relaxed max-w-2xl">
              Estudio sistemático de los dictámenes legales contemporáneos y
              memorización de los textos que estructuran el entramado legal de
              la jurisprudencia islámica tradicional.
            </p>
          </div>

          <!-- Hito 3 -->
          <div class="relative pl-12 group">
            <div
              class="absolute left-[13px] top-2 w-2 h-2 rounded-full bg-oro/40 group-hover:bg-oro transition-colors duration-300"
            >
            </div>

            <h3
              class="font-serif text-xl font-bold text-chocolate mb-3 group-hover:text-granate transition-colors"
            >
              Línea de Maestros y Autorización
            </h3>
            <p class="text-chocolate/80 text-base leading-relaxed max-w-2xl">
              Instrucción directa recibida de destacados sabios y jurisconsultos
              de la comunidad islámica contemporánea, manteniendo el compromiso
              con los valores y modales de los rectos predecesores.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
